{
  "name": "maniac",
  "version": "1.0.0",
  "description": "Your maniacal toolkit — unrestrict, compress, encrypt",
  "type": "module",
  "bin": {
    "maniac": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun src/cli.tsx",
    "build": "tsc -b",
    "start": "bun dist/cli.js",
    "prepare": "bun run build",
    "compile:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/cli.tsx src/workers/download-worker.ts ../../packages/shared/src/workers/compression-worker.ts ../../packages/shared/src/workers/picocrypt-worker.ts --outfile dist/maniac-darwin-arm64",
    "compile:windows-x64": "bun build --compile --target=bun-windows-x64 src/cli.tsx src/workers/download-worker.ts ../../packages/shared/src/workers/compression-worker.ts ../../packages/shared/src/workers/picocrypt-worker.ts --outfile dist/maniac-windows-x64.exe",
    "compile": "bun run compile:darwin-arm64 && bun run compile:windows-x64"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@caynac/shared": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "commander": "^12.1.0",
    "ink": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.4.0"
  }
}
