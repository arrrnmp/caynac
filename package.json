{
  "name": "caynac",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:maniac": "cd apps/maniac && bun run dev",
    "dev:caymann": "cd apps/caymann && bun run dev",
    "build": "bunx tsc -b apps/maniac apps/caymann",
    "compile:maniac:darwin-arm64": "bun build --compile --format=esm --bytecode --target=bun-darwin-arm64 apps/maniac/src/cli.tsx apps/maniac/src/workers/download.worker.ts packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/maniac-darwin-arm64",
    "compile:maniac:darwin-x64-baseline": "bun build --compile --format=esm --bytecode --target=bun-darwin-x64-baseline apps/maniac/src/cli.tsx apps/maniac/src/workers/download.worker.ts packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/maniac-darwin-x64-baseline",
    "compile:maniac:darwin-x64-modern": "bun build --compile --format=esm --bytecode --target=bun-darwin-x64-modern apps/maniac/src/cli.tsx apps/maniac/src/workers/download.worker.ts packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/maniac-darwin-x64-modern",
    "compile:maniac:windows-arm64": "bun build --compile --format=esm --bytecode --target=bun-windows-arm64 apps/maniac/src/cli.tsx apps/maniac/src/workers/download.worker.ts packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/maniac-windows-arm64.exe",
    "compile:maniac:windows-x64-baseline": "bun build --compile --format=esm --bytecode --target=bun-windows-x64-baseline apps/maniac/src/cli.tsx apps/maniac/src/workers/download.worker.ts packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/maniac-windows-x64-baseline.exe",
    "compile:maniac:windows-x64-modern": "bun build --compile --format=esm --bytecode --target=bun-windows-x64-modern apps/maniac/src/cli.tsx apps/maniac/src/workers/download.worker.ts packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/maniac-windows-x64-modern.exe",
    "compile:caymann:darwin-arm64": "bun build --compile --format=esm --bytecode --target=bun-darwin-arm64 apps/caymann/src/cli.tsx packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/caymann-darwin-arm64",
    "compile:caymann:darwin-x64-baseline": "bun build --compile --format=esm --bytecode --target=bun-darwin-x64-baseline apps/caymann/src/cli.tsx packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/caymann-darwin-x64-baseline",
    "compile:caymann:darwin-x64-modern": "bun build --compile --format=esm --bytecode --target=bun-darwin-x64-modern apps/caymann/src/cli.tsx packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/caymann-darwin-x64-modern",
    "compile:caymann:windows-arm64": "bun build --compile --format=esm --bytecode --target=bun-windows-arm64 apps/caymann/src/cli.tsx packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/caymann-windows-arm64.exe",
    "compile:caymann:windows-x64-baseline": "bun build --compile --format=esm --bytecode --target=bun-windows-x64-baseline apps/caymann/src/cli.tsx packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/caymann-windows-x64-baseline.exe",
    "compile:caymann:windows-x64-modern": "bun build --compile --format=esm --bytecode --target=bun-windows-x64-modern apps/caymann/src/cli.tsx packages/shared/src/workers/compression.worker.ts packages/shared/src/workers/picocrypt.worker.ts --outfile dist/caymann-windows-x64-modern.exe",
    "compile:maniac": "bun run compile:maniac:darwin-arm64 && bun run compile:maniac:darwin-x64-baseline && bun run compile:maniac:darwin-x64-modern && bun run compile:maniac:windows-arm64 && bun run compile:maniac:windows-x64-baseline && bun run compile:maniac:windows-x64-modern",
    "compile:caymann": "bun run compile:caymann:darwin-arm64 && bun run compile:caymann:darwin-x64-baseline && bun run compile:caymann:darwin-x64-modern && bun run compile:caymann:windows-arm64 && bun run compile:caymann:windows-x64-baseline && bun run compile:caymann:windows-x64-modern",
    "compile": "bun run compile:maniac && bun run compile:caymann"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "react-devtools-core": "^7.0.1"
  }
}
